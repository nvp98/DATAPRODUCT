                                            <td style="width:124px"><input  class="form-control" type="number" name="ListChiTiet[@i].KhoiLuongXeGoong" value="@Model[i].KhoiLuongXeGoong" /></td>
                                            <td style="width:124px"><input   class="form-control" type="number" name="ListChiTiet[@i].KhoiLuongThung" value="@Model[i].KhoiLuongThung" /></td>
                                            <td style="width:160px"><input class="form-control" type="number" name="ListChiTiet[@i].KLThungGangLong" value="@Model[i].KLThungGangLong" /></td>
                                            <td style="width:159px"><input class="form-control" type="text" name="ListChiTiet[@i].KLGangLongCanRay" value="@Model[i].KLGangLongCanRay" /></td>

                                            <td style="width:91px"><input   type="checkbox" name="ListChiTiet[@i].VanChuyenHRC1" value="1" @(Model[i].VanChuyenHRC1 == 1 ? "checked" : "") /></td>
                                            <td style="width:70px"><input   type="checkbox" name="ListChiTiet[@i].Duc1" value="1" @(Model[i].Duc1 == 1 ? "checked" : "") /></td>
                                            <td style="width:91px"><input type="checkbox" name="ListChiTiet[@i].VanChuyenHRC2" value="1" @(Model[i].VanChuyenHRC2 == 1 ? "checked" : "") /></td>
                                            <td style="width:70px"><input  type="checkbox" name="ListChiTiet[@i].Duc2" value="1" @(Model[i].Duc2 == 1 ? "checked" : "") /></td>

                                            <td style="width:102px"><input  class="form-control" type="text" name="ListChiTiet[@i].PhanLoai" value="@Model[i].PhanLoai" /></td>
                                            <td style="width:84px"><input  class="form-control" type="text" name="ListChiTiet[@i].Gio" value="@Model[i].Gio" /></td>
                                            <td style="width:98px"><input class="form-control" type="text" name="ListChiTiet[@i].GhiChu" value="@Model[i].GhiChu" /></td>
                                            <td><input class="form-control" type="text" name="ListChiTiet[@i].GioNM" value="@Model[i].GioNM" /></td>
                                        </tr>
                                        index++;
                                    }
                                    
                                </tbody>
                                <tfoot style="display: table; width: 100%; table-layout: fixed;">
                                    <tr>
                                        <td colspan="6" class="text-center font-weight-bold"><b>Tổng khối lượng</b></td>
                                        <td class="font-weight-bold">@Model.Sum(x => x.KLGangLongCanRay)</td>
                                        <td></td>
                                        <td></td>

                                    </tr>
                                </tfoot>
                            </table>

                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
}
    <script>
    $(document).ready(function () {
        $(document).on('input', 'input[name="KLThungGangLong"], input[name="KhoiLuongThung"]', function() {
            // Lấy hàng (row) hiện tại chứa ô đang thay đổi
            const row = $(this).closest('tr');

            // Lấy giá trị từ các ô input và chuyển thành số (mặc định 0 nếu không hợp lệ)
            const klThungGangLong = parseFloat(row.find('input[name="KLThungGangLong"]').val()) || 0;
            const khoiLuongThung = parseFloat(row.find('input[name="KhoiLuongThung"]').val()) || 0;

            // Tính toán KLGangLongCanRay và làm tròn 2 chữ số thập phân
            const klGangLongCanRay = (klThungGangLong - khoiLuongThung).toFixed(2);

            // Gán giá trị vào ô KLGangLongCanRay (luôn hiển thị 2 chữ số thập phân)
            row.find('input[name="KLGangLongCanRay"]').val(klGangLongCanRay);
        });
    });
</script>
