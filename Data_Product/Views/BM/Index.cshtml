    <script>
    $(document).ready(function () {
            let maxIndex = 0;
            
            function loadTableData(selectedDate, selectedLoCao, selectedKip) {
                $.ajax({
                    url: "/BM/GetSoMeGangBKMis",
                    type: "GET",
                    data: {
                        ngay: selectedDate,
                        ID_LoCao: selectedLoCao,
                        IDKip: selectedKip
                    },
                    success: function (data) {
                        maxIndex = data.length;
                        let tableBody = $("#dataTable tbody");
                        tableBody.find("tr:not(#addRowBtnContainer)").remove();

                        $.each(data, function (index, item) {
                            let soMe = item.testPatternCode ? item.testPatternCode : "";
                            
                            let thungSo = soMe.length >= 2 ? soMe.slice(-2) : "";
                            let phanLoai = item.classifyName ? item.classifyName : "";
                            let time = item.patterntime ? item.patterntime.replace(/H/g, ":") : "";
                            
                            let row = `
                                <tr>
                                    <td class='text-center delItem' >

                                        <a class="btn btn-danger btn-sm" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                    <td><input type="text" name="SoMe" class="form-control" value="${soMe}"  style="width: 150px;" required></td>
                                        <td><input type="number" name="ThungSo" class="form-control" step="1" required="" value="${thungSo}"required></td>
                                        <td><input type="number" name="KhoiLuongXeGoong" class="form-control" required></td>
                                        <td><input id="KLThung_${index}" name="KhoiLuongThung" type="number" step="0.01" min="0.01" class="form-control" value="" required></td>
                                        <td><input id="KLThungGL_${index}" name="KLThungGangLong" type="number" step="0.01" min="0.01" class="form-control" value="" required></td>
                                        <td><input id="KLGLCR_${index}" name="KLGangLongCanRay" type="text" class="form-control" value=""  required></td>
                                    <td>
                                        <input type="hidden" name="VanChuyenHRC1" value="0" />
                                        <input type="checkbox" name="VanChuyenHRC1" value="1" class="form-check-input">
                                    </td>
                                    <td>
                                        <input type="hidden" name="Duc1" value="0" />
                                        <input type="checkbox" name="Duc1" value="1" class="form-check-input">
                                    </td>
                                     <td>
                                        <input type="hidden" name="VanChuyenHRC2" value="0" />
                                        <input type="checkbox" name="VanChuyenHRC2" value="1" class="form-check-input">
                                    </td>
                                    <td>
                                        <input type="hidden" name="Duc2" value="0" />
                                        <input type="checkbox" name="Duc2" value="1" class="form-check-input">
                                    </td>
                                    <td><input type="text" name="PhanLoai" class="form-control" value="${phanLoai}" ></td>
                                    <td><input type="text" name="Gio" class="form-control" value="${time}" ></td>
                                    <td><input type="text" name="GhiChu" class="form-control" value="" ></td>
                                    <td><input type="text" name="GioNM" class="form-control" value="${time}" ></td>
                                </tr>
                            `;

                            $(row).insertBefore("#addRowBtnContainer");
                        });
                    },
                    error: function (err) {
                        console.error("Lỗi tải dữ liệu: ", err);
                    }
                });
            }

            $("#IDCa").change(function () {
                let selectedCa = $(this).val();
                let selectedDate = $("#ID_Day").val();
                let kipDropdown = $("#CaKip");

                // Reset dropdown
                kipDropdown.empty().append("<option value='null'>-- Kíp làm việc --</option>").prop("disabled", true);

                if (!selectedCa || selectedCa === "null" || !selectedDate) return;

                $.ajax({
                    url: "/BM/GetKipFromCa",
                    type: "GET",
                    data: { Ngay: selectedDate, Ca: selectedCa },
                    success: function (res) {
                        kipDropdown.empty().prop("disabled", true);
                        if (res.length > 0) {
                            $.each(res, function (index, item) {
                                kipDropdown.append(`<option value='${item.iD_Kip}' data-info='${item.tenKip}'>${item.tenKip}</option>`);
                            });
                        } else {
                            kipDropdown.append("<option value='null' disabled selected>-- Kíp làm việc --</option>");
                        }
                    },
                    error: function (err) {
                        console.error("Lỗi khi tải dữ liệu kíp: ", err);
                        kipDropdown.empty().append("<option value='null' disabled selected>-- Kíp làm việc --</option>").prop("disabled", true);
                    }
                });
            });

            $("#ID_Day, #IDLoCao, #IDCa").change(function () {

                let selectedDate = $("#ID_Day").val();
                let selectedLoCao = $("#IDLoCao").val();
                let selectedCa = $("#IDCa").val();

                if (selectedLoCao && selectedCa && selectedLoCao !== "null" && selectedCa !== "null" ) {
                    $("#dataTable tbody").find("tr:not(#addRowBtnContainer)").remove();
                    loadTableData(selectedDate, selectedLoCao, selectedCa);
                }

          
           });
          $("#addRowBtn").click(function (e) {
                e.preventDefault();
                let row = `
                    <tr>
                        <td class='text-center delItem' >
                            <a class="btn btn-danger btn-sm" title="Xóa">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                        <td><input type="text" name="SoMe" class="form-control" required ></td>
                        <td><input type="number" name="ThungSo" class="form-control " required ></td>
                            <td><input type="number" name="KhoiLuongXeGoong" value="0" class="form-control"required ></td>

                            <td><input id="KLThung_${maxIndex}" name="KhoiLuongThung" type="number" value="0" step="0.01" min="0.01" class="form-control"required ></td>
                            <td><input id="KLThungGL_${maxIndex}" name="KLThungGangLong" type="number" value="0" step="0.01" min="0.01" class="form-control" required ></td>
                            <td><input id="KLGLCR_${maxIndex}" name="KLGangLongCanRay" type="text" value="0" class="form-control"  readonly required></td>

                        <td><input type="checkbox" name="VanChuyenHRC1" class="form-check-input"></td>
                        <td><input type="checkbox" name="Duc1" class="form-check-input"></td>
                        <td><input type="checkbox" name="VanChuyenHRC2" class="form-check-input"></td>
                        <td><input type="checkbox" name="Duc2" class="form-check-input"></td>
                        <td><input type="text" name="PhanLoai" class="form-control" ></td>
                        <td><input type="text" name="Gio" class="form-control" ></td>
                        <td><input type="text" name="GhiChu" class="form-control" ></td>
                        <td><input type="text" name="GioNM" class="form-control" ></td>

                    </tr>

                `;
                $(row).insertBefore("#addRowBtnContainer");
                maxIndex++;
          });
              $(document).on("click", ".delItem a", function (e) {
                e.preventDefault();
                $(this).closest("tr").remove();
            });

        
                $(document).on("change", "#IDTaiKhoan", function() {
                  const isHRC1Selected = $(this).val() !== ""; // Kiểm tra có chọn đại diện HRC1 không
                   $("input[name='Duc1']").prop("checked", isHRC1Selected); // Tích/bỏ tích tất cả checkbox "Đục 1"
                   $("input[name='VanChuyenHRC1']").prop("checked", isHRC1Selected);
                });
                    $(document).on("change", "#IDTaiKhoanHRC2", function() {
                      const isHRC1Selected = $(this).val() !== ""; // Kiểm tra có chọn đại diện HRC1 không
                       $("input[name='Duc2']").prop("checked", isHRC1Selected); // Tích/bỏ tích tất cả checkbox "Đục 1"
                       $("input[name='VanChuyenHRC2']").prop("checked", isHRC1Selected);
                    });

            $(document).on("input", "input[id^='KLThung_'], input[id^='KLThungGL_']", function () {
                let index = $(this).attr("id").split("_")[1];
                let klThung = parseFloat($("#KLThung_" + index).val()) || 0;
                let klThungGL = parseFloat($("#KLThungGL_" + index).val()) || 0;

                let klGLCR = (klThungGL - klThung) ? parseFloat((klThungGL - klThung).toFixed(2)) : 0;

                $("#KLGLCR_" + index).val(klGLCR);
            });

        $("#xacnhan").click(function (e) {
        e.preventDefault();

            let selectedButton = $(this).attr("id");

        // Validate dữ liệu đầu vào
        let selectedLoCao = $("#IDLoCao").val();
        if (!selectedLoCao || selectedLoCao == "null") {
            alert('Vui lòng chọn Lò cao!');
            return false;
        }

        let selectedCa = $("#IDCa").val();
        if (!selectedCa || selectedCa == "null") {
            alert('Vui lòng chọn Ca Kíp!');
            return false;
        }

        let selectedTaiKhoan = $("#IDTaiKhoan").val();
        selectedTaiKhoan = (!selectedTaiKhoan || selectedTaiKhoan === "null") ? null : parseInt(selectedTaiKhoan);
        let selectedTaiKhoanHRC2 = $("#IDTaiKhoanHRC2").val();
        selectedTaiKhoanHRC2 = (!selectedTaiKhoanHRC2 || selectedTaiKhoanHRC2 === "null") ? null : parseInt(selectedTaiKhoanHRC2);

             // ID_PhongBan_HRC2: $("#IDPhongBan_HRC2 option:selected").data("info") ? $("#IDPhongBan_HRC2 option:selected").data("info").split("-")[0] : null,
        if ((!selectedTaiKhoan || selectedTaiKhoan == "null") && (!selectedTaiKhoanHRC2 || selectedTaiKhoanHRC2 == "null")) {
            alert('Vui lòng chọn ít nhất một Đại diện bên nhận (HRC1 hoặc HRC2)!');
            return false;
        }

        let selectedTaiKhoan_QLCL = $("#IDTaiKhoan_QLCL").val();
        if (!selectedTaiKhoan_QLCL || selectedTaiKhoan_QLCL == "null") {
            alert('Vui lòng chọn Đại diện bên nhận QLCL!');
            return false;
        }

        let selectedID_TaiKhoan = $("#IDNhanVienTT").val();
        if (!selectedID_TaiKhoan || selectedID_TaiKhoan == "null") {
            alert('Vui lòng chọn Nhân viên thống kê phê duyệt!');
            return false;
        }

        let selectID_TaiKhoan_View = $("#IDNhanVienView").val();
        if (!selectID_TaiKhoan_View || selectID_TaiKhoan_View == "null") {
            alert('Vui lòng chọn Nhân viên thống kê nhận BBGN!');
            return false;
        }

        // Chuẩn bị dữ liệu với kiểm tra null/undefined
        let data = {

            ID_NhanVien_BG: $("#ID_NhanVien_BG").data("info") || null,
            ID_PhongBan_BG: $("#ID_PhongBan_BG").data("info") ? $("#ID_PhongBan_BG").data("info").split("-")[0] : null,
            ID_Xuong_BG: $("#ID_PhongBan_BG").data("info") ? $("#ID_PhongBan_BG").data("info").split("-")[1] : null,
            ID_ViTri_BG: $("#ID_ViTri_BG").data("info") || null,

            ID_NhanVien_HRC: selectedTaiKhoan,
            ID_PhongBan_HRC: $("#IDPhongBan option:selected").data("info") ? $("#IDPhongBan option:selected").data("info").split("-")[0] : null,
            ID_Xuong_HRC: $("#IDPhongBan option:selected").data("info") ? ($("#IDPhongBan option:selected").data("info").split("-")[1] === "null" ? null : $("#IDPhongBan option:selected").data("info").split("-")[1]) : null,
            ID_ViTri_HRC: $("#IDChucVu option:selected").data("info") || null,

            ID_NhanVien_HRC2: selectedTaiKhoanHRC2,
            ID_PhongBan_HRC2: $("#IDPhongBan_HRC2 option:selected").data("info") ? $("#IDPhongBan_HRC2 option:selected").data("info").split("-")[0] : null,
                // ID_PhongBan_HRC2: "1",
            ID_ViTri_HRC2: $("#IDChucVu_HRC2 option:selected").data("info") || null,
                // ID_ViTri_HRC2: "2",
            ID_Xuong_HRC2: $("#IDPhongBan_HRC2 option:selected").data("info") ? ($("#IDPhongBan_HRC2 option:selected").data("info").split("-")[1] === "null" ? null : $("#IDPhongBan_HRC2 option:selected").data("info").split("-")[1]) : null,
                // ID_Xuong_HRC2: "2",

            ID_Nhanvien_NL: $("#IDTaiKhoan_NVNL").val() || null,
            ID_PB_NL: $("#IDPhongBan_NVNL option:selected").data("info") ? $("#IDPhongBan_NVNL option:selected").data("info").split("-")[0] : null,
            ID_Vitri_NL: $("#IDChucVu_NVNL option:selected").data("info") || null,
            ID_Xuong_NL: $("#IDPhongBan_NVNL option:selected").data("info") ? ($("#IDPhongBan_NVNL option:selected").data("info").split("-")[1] === "null" ? null : $("#IDPhongBan_NVNL option:selected").data("info").split("-")[1]) : null,

            ID_NhanVien_QLCL: selectedTaiKhoan_QLCL,
            ID_PhongBan_QLCL: $("#IDPhongBan_QLCL option:selected").data("info") ? $("#IDPhongBan_QLCL option:selected").data("info").split("-")[0] : null,
            ID_Xuong_QLCL: $("#IDPhongBan_QLCL option:selected").data("info") ? ($("#IDPhongBan_QLCL option:selected").data("info").split("-")[1] === "null" ? null : $("#IDPhongBan_QLCL option:selected").data("info").split("-")[1]) : null,
            ID_ViTri_QLCL: $("#IDChucVu_QLCL option:selected").data("info") || null,

            NgayXuly_BG: $("#ID_Day").val() || null,
            ID_Kip: $("#CaKip").val() || null,
            Kip: $("#CaKip option:selected").data("info") || null,
            Ca: selectedCa,
            NoiDungTrichYeu: $("#NoiDungTrichYeu").val() || null,
            ID_TaiKhoan: selectedID_TaiKhoan,
            ID_TaiKhoan_View: selectID_TaiKhoan_View,
            ID_LOCAO: selectedLoCao
        };

         

        console.log("Data to be sent:", data);
            console.log(JSON.stringify(data));

        // Thêm CSRF token nếu cần
        let token = $('input[name="__RequestVerificationToken"]').val();

        $.ajax({
            url: "/BM/SubmitData_BBGangLong_GangThoi",
            type: "POST",
            contentType: "application/json",
            headers: token ? { "RequestVerificationToken": token } : {},
            data: JSON.stringify(data),
            processData: false,
            success: function(response) {
                if (response && response.success) {
                    
                    if (response.id_BBGL) {
                            submitChiTietBBGangLong(response.id_BBGL, selectedButton);
                              //  alert("Gửi dữ liệu thành công!");
                    }
                       // alert("Gửi dữ liệu thành công!");
                } else {
                    alert("Gửi dữ liệu thất bại: " + (response && response.message || "Vui lòng thử lại!"));
                }
            },
            error: function(xhr, status, error) {
                console.error("Error:", xhr.responseText);
                let errorMsg = "Lỗi khi gửi dữ liệu";
                try {
                    let response = JSON.parse(xhr.responseText);
                    errorMsg += ": " + (response.message || xhr.statusText);
                } catch (e) {
                    errorMsg += ": " + xhr.statusText;
                }
                alert(errorMsg);
            }
        });
    });
         $("#btnSave").click(function (e) {
