@using Data_Product.Models
@using System.Security.Claims;
@using Data_Product.Repositorys;
@using Microsoft.EntityFrameworkCore;
@inject Data_Product.Repositorys.DataContext _context
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="~/Content/assets/Chonse/chosen.jquery.js"></script>
<link href="~/Content/assets/Chonse/chosen.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
@if (TempData["msgSuccess"] != null)
{
    @Html.Raw(TempData["msgSuccess"])
}
@if (TempData["msgError"] != null)
{
    @Html.Raw(TempData["msgError"])
}
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";

    Pager pager = new Pager();
    int pageNo = 0;
    if (ViewBag.Pager != null)
    {
        pager = ViewBag.Pager;
        pageNo = pager.CurrentPage;
    }
}

@using (Html.BeginForm("Index", "BM", FormMethod.Post, new { enctype = "multipart/form-data", id = "Index" }))
{
    <div class="app-main__outer">
        <div class="app-main__inner" style="display:block;padding-bottom: 0px;">
            <div class="tab-content">
                <div class="row">
                    <div class="card">
                        <div class="row" style="width:100%">
                            <div style="display: flex; border-bottom: 0.8px solid #E8E8E8; position: fixed; background-color: #F9F9F9; z-index: 9999999 !important;">
                                <div style="flex: 2; text-align: left; padding: 2% 2% 2% 0%;">
                                    <span class="text-muted small pt-2 ps-1">
                                        <b style="color:#06428b">
                                            BM.16/QT.05.09
                                        </b>
                                    </span>
                                </div>
                                <div class="col-4 " style="padding: 2%  2%  2% 0%; ">
                                    <button type="button" class="btn btn-danger" onclick="window.location.href='@Url.Action("Index", "Menu")';">
                                        <i class="bi bi-x-lg"></i>
                                        <span class="small pt-2 ps-1" style="color: white;">
                                            Hủy bỏ
                                        </span>
                                    </button>
                                    <button type="submit" class="btn btn-primary" name="xacnhan" id="xacnhan" value="1">
                                        <i class="bi bi-send"></i>
                                        <span class="small pt-2 ps-1" style="color: white;">
                                            Gửi phiếu
                                        </span>
                                    </button>
                                    <button type="submit" class="btn btn-success" name="btnSave" id="btnSave" value="1">
                                        <i class="bi bi-send"></i>
                                        <span class="small pt-2 ps-1" style="color: white;">
                                            Lưu phiếu
                                        </span>
                                    </button>
                                </div>
                            </div>
                            <div class ="row" style="width:100%; padding-top:7.5%;">
                                <!-- Bọc div tổng để căn lề đẹp và có khoảng trắng -->
                                <div class="container py-3">
                                    <div class="d-flex justify-content-between align-items-center flex-wrap bg-light rounded p-4 shadow-sm gap-4" style="height: 67px;margin-top: 4px;width: 99.5%;margin-left: 4px;">

                                        <!-- Ngày làm việc -->
                                        <div class="d-flex align-items-center" style="min-width: 260px;">
                                            <label for="ID_Day" class="me-2 mb-0 fw-semibold" style="width: 120px;">Ngày làm việc:</label>
                                            <input type="date" id="ID_Day" name="ID_Day"
                                                   class="form-control form-control-sm shadow-sm"
                                                   value="@ViewBag.DefaultDate"
                                                   onkeydown="return false;"
                                                   style="flex: 1;" />
                                        </div>

                                        <!-- ID Lò cao -->
                                        <div class="d-flex align-items-center" style="min-width: 240px;">
                                            <label for="IDLoCao" class="me-2 mb-0 fw-semibold" style="width: 100px;">ID Lò cao:</label>
                                            <select class="form-control form-control-sm shadow-sm" name="LoCao" id="IDLoCao" style="flex: 1;">
                                                <option value='null'>-- ID Lò cao --</option>
                                                <option value='1'>Lò cao 1</option>
                                                <option value='2'>Lò cao 2</option>
                                                <option value='3'>Lò cao 3</option>
                                                <option value='4'>Lò cao 4</option>
                                            </select>
                                        </div>

                                        <!-- Ca làm việc -->
                                        <div class="d-flex align-items-center" style="min-width: 200px;">
                                            <label for="IDCa" class="me-2 mb-0 fw-semibold" style="width: 100px;">Ca làm việc:</label>
                                            <select class="form-control form-control-sm shadow-sm SelectCA" name="IDCa" id="IDCa" style="flex: 1;">
                                                <option value='null'>-- Ca --</option>
                                                <option value='1'>1</option>
                                                <option value='2'>2</option>
                                            </select>
                                        </div>

                                        <!-- Kíp làm việc -->
                                        <div class="d-flex align-items-center" style="min-width: 200px;">
                                            <label for="CaKip" class="me-2 mb-0 fw-semibold" style="width: 100px;">Kíp làm việc:</label>
                                            <select class="form-control form-control-sm shadow-sm" name="CaKip" id="CaKip" style="flex: 1;" disabled>
                                            </select>
                                        </div>

                                    </div>
                                </div>
                            </div>
                                <style>
                                    /* Tạo hiệu ứng viền 3D */
                                    .form-control, .form-control-sm {
                                        transition: all 0.3s ease-in-out;
                                        border: 1px solid #ccc;
                                        border-radius: 4px;
                                        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
                                    }

                                        .form-control:focus, .form-control-sm:focus {
                                            border-color: red; /* Màu viền khi focus */
                                            box-shadow: 0 0 8px rgba(102, 175, 233, 0.6); /* Màu bóng đổ khi focus */
                                            transform: translateY(-2px); /* Di chuyển nhẹ lên khi focus để tạo hiệu ứng 3D */
                                        }

                                        .form-control:hover, .form-control-sm:hover {
                                            border-color: #007bff; /* Màu viền khi hover */
                                            box-shadow: 0 0 8px rgba(0, 123, 255, 0.5); /* Màu bóng đổ khi hover */
                                            transform: translateY(-2px); /* Di chuyển nhẹ lên khi hover */
                                        }

                                        .form-control:disabled {
                                            background-color: #f8f9fa;
                                            border-color: #ddd;
                                            box-shadow: none;
                                        }
                                </style>
                                <div class="d-flex justify-content-between align-items-center flex-wrap px-3 gap-3 py-2" style="margin-top:-10px">

                                    @{
                                        var TenTaiKhoan = User.FindFirstValue(ClaimTypes.Name);
                                        var TaiKhoan = _context.Tbl_TaiKhoan.FirstOrDefault(x => x.TenTaiKhoan == TenTaiKhoan);
                                        var PhongBan = _context.Tbl_PhongBan.FirstOrDefault(x => x.ID_PhongBan == TaiKhoan.ID_PhongBan);
                                        var PhanXuong = _context.Tbl_Xuong.FirstOrDefault(x => x.ID_Xuong == TaiKhoan.ID_PhanXuong);
                                        var ViTri = _context.Tbl_ViTri.FirstOrDefault(x => x.ID_ViTri == TaiKhoan.ID_ChucVu);
                                    }

                                    <!-- Đại diện bên giao -->
                                    <div class="d-flex align-items-center justify-content-start flex-grow-1 bg-light rounded shadow-sm px-3"
                                         style="min-width: 300px; max-width: 31.5%; height: 50px;">
                                        <label class="mb-0 me-2 fw-semibold text-nowrap" style="width: 130px;">Đại diện bên giao:</label>
                                        <span id="ID_NhanVien_BG" class="flex-grow-1" data-info="@TaiKhoan.ID_TaiKhoan" style="font-size: 14px;">
                                            @TaiKhoan.TenTaiKhoan - @TaiKhoan.HoVaTen
                                        </span>
                                    </div>

                                    <!-- Chức vụ -->
                                    <div class="d-flex align-items-center justify-content-start flex-grow-1 bg-light rounded shadow-sm px-3"
                                         style="min-width: 300px; max-width: 31.5%; height: 50px;">
                                        <label class="mb-0 me-2 fw-semibold text-nowrap" style="width: 130px;">Chức vụ:</label>
                                        <span id="ID_ViTri_BG" class="flex-grow-1" data-info="@ViTri.ID_ViTri" style="font-size: 14px;">
                                            @ViTri.TenViTri
                                        </span>
                                    </div>

                                    <!-- BP/NM -->
                                    <div class="d-flex align-items-center justify-content-start flex-grow-1 bg-light rounded shadow-sm px-3"
                                         style="min-width: 300px; max-width: 33%; height: 50px;">
                                        <label class="mb-0 me-2 fw-semibold text-nowrap" style="width: 130px;">BP/NM:</label>
                                        <span id="ID_PhongBan_BG" class="flex-grow-1" data-info="@TaiKhoan.ID_PhongBan-@PhanXuong.ID_Xuong" style="font-size: 14px;">
                                            @PhongBan.TenPhongBan - @PhanXuong.TenXuong
                                        </span>
                                    </div>

                                </div>

                                <div class="col-lg-12" style="display: flex; space-around: space-between; padding-bottom: 1%; margin-top: 5px;">
                                    <!-- Đại diện bên nhận HRC -->
                                    <div class="d-flex align-items-center bg-light rounded p-2 mb-3" style="min-height: 57px;width: 31.8%; gap: 1rem; margin-right: 27px;">
                                        <span class="text-dark mb-0" style="font-size: 14px; white-space: nowrap;">
                                            Đại diện bên nhận HRC1 <span class="text-danger">(*)</span>:
                                        </span>
                                        @Html.DropDownList("IDTaiKhoan", null, "----- Chọn đại diện bên nhận -----", new
                                            {
                                                id = "IDTaiKhoan",
                                                name = "IDTaiKhoan",
                                                @class = "form-select flex-grow-1"
                                            })
                                        <script type="text/javascript">
                                            $("#ID_Day").change(function () {
                                                $.get("/BM/Ngay", { Ngay: $("#ID_Day").val() }, function (data) {
                                                    if (data[0] != null) {
                                                        $("#IDCa").empty();
                                                        $("#IDCa").append("<option value ='" + null + "'>" + "--Chọn Ca--" + "</option>")
                                                        $.each(data, function (index, row) {
                                                            $("#IDCa").append("<option value ='" + row.iD_Kip + "' >" + row.tenCa + "</option>");
                                                        });
                                                    } else {
                                                        $("#IDCa").empty();
                                                        $("#IDCa").append("<option value ='" + 0 + "'>" + "--Không có ca làm việc--" + "</option>")
                                                    }
                                                });
                                            });
                                        </script>
                                    </div>
                                    

                                    <!-- Chức vụ -->
                                    <div class="d-flex align-items-center bg-light rounded p-2 mb-3" style="min-height: 57px; gap: 1rem;width: 31.8%;margin-right: 22px;">
                                        <span class="text-dark mb-0" style="font-size: 14px; white-space: nowrap;">
                                            Chức vụ <span class="text-danger">(*)</span>:
                                        </span>
                                        <select class="form-select flex-grow-1" name="IDChucVu" id="IDChucVu" disabled="disabled">
                                        </select>
                                        <script type="text/javascript">
                                            $("#IDTaiKhoan").change(function () {
                                                $.get("/BM/ChucVu", { IDTaiKhoan: $("#IDTaiKhoan").val() }, function (data) {
                                                    if (data[0] != null) {
                                                        $("#IDChucVu").empty();
                                                        $.each(data, function (index, row) {
                                                            $("#IDChucVu").append("<option value='" + row.iD_ChucVu + "' data-info='" + row.iD_ChucVu + "' selected>" + row.tenChucVu + "</option>");
                                                        });
                                                    } else {
                                                        $("#IDChucVu").empty();
                                                        $("#IDChucVu").append("<option value='0'>--Không có chức vụ--</option>");
                                                    }
                                                });
                                            });
                                        </script>
                                    </div>

                                    <!-- BP/NM -->
                                    <div class="d-flex align-items-center bg-light rounded p-2 mb-3" style="min-height: 57px; gap: 1rem;width: 31.8%;margin-right: 22px;">
                                        <span class="text-dark mb-0" style="font-size: 14px; white-space: nowrap;">
                                            BP/NM <span class="text-danger">(*)</span>:
                                        </span>
                                        <select class="form-select flex-grow-1" name="IDPhongBan" id="IDPhongBan" disabled="disabled">
                                        </select>
                                        <script type="text/javascript">
                                            $("#IDTaiKhoan").change(function () {
                                                $.get("/BM/PhongBan", { IDTaiKhoan: $("#IDTaiKhoan").val() }, function (data) {
                                                    if (data[0] != null) {
                                                        $("#IDPhongBan").empty();
                                                        $.each(data, function (index, row) {
                                                            $("#IDPhongBan").append("<option value='" + row.iD_PhongBan + "' data-info='" + row.iD_PhongBan + "-" + row.iD_PhanXuong + "' selected>" + row.tenPhongBan + "</option>");
                                                        });
                                                    } else {
                                                        $("#IDPhongBan").empty();
                                                        $("#IDPhongBan").append("<option value='0'>--Không có chức vụ--</option>");
                                                    }
                                                });
                                            });
                                        </script>
                                    </div>
                                </div>

                                <!-- Đại diện bên nhận HRC2 -->
                                <div class="col-lg-12" style="display: flex; space-around: space-between; padding-bottom: 1%; margin-top:-24px">
                                    <!-- Đại diện bên nhận HRC2 -->
                                    <div class="d-flex align-items-center bg-light rounded p-2 mb-3" style="min-height: 57px;width: 31.8%; gap: 1rem; margin-right: 27px;">
                                        <span class="text-dark mb-0" style="font-size: 14px; white-space: nowrap;">
                                            Đại diện bên nhận HRC2 <span class="text-danger">(*)</span>:
                                        </span>
                                        @Html.DropDownList("IDTaiKhoanHRC2", null, "----- Chọn đại diện bên nhận -----", new
                                            {
                                                id = "IDTaiKhoanHRC2",
                                                name = "IDTaiKhoanHRC2",
                                                @class = "form-select flex-grow-1"
                                            })
                                        <script type="text/javascript">
                                            $("#ID_Day").change(function () {
                                                $.get("/BM/Ngay", { Ngay: $("#ID_Day").val() }, function (data) {
                                                    if (data[0] != null) {
                                                        $("#IDCa").empty();
                                                        $("#IDCa").append("<option value ='" + null + "'>" + "--Chọn Ca--" + "</option>")
                                                        $.each(data, function (index, row) {
                                                            $("#IDCa").append("<option value ='" + row.iD_Kip + "' >" + row.tenCa + "</option>");
                                                        });
                                                    } else {
                                                        $("#IDCa").empty();
                                                        $("#IDCa").append("<option value ='" + 0 + "'>" + "--Không có ca làm việc--" + "</option>")
                                                    }
                                                });
                                            });
                                        </script>
                                    </div>

                                    <!-- Chức vụ -->
                                    <div class="d-flex align-items-center bg-light rounded p-2 mb-3" style="min-height: 57px; gap: 1rem;width: 31.8%;margin-right: 22px;">
                                        <span class="text-dark mb-0" style="font-size: 14px; white-space: nowrap;">
                                            Chức vụ <span class="text-danger">(*)</span>:
                                        </span>
                                        <select class="form-select flex-grow-1" name="IDChucVu" id="IDChucVu_HRC2" disabled="disabled">
                                        </select>
                                        <script type="text/javascript">
                                            $("#IDTaiKhoanHRC2").change(function () {
                                                $.get("/BM/ChucVu", { IDTaiKhoan: $("#IDTaiKhoanHRC2").val() }, function (data) {
                                                    if (data[0] != null) {
                                                        $("#IDChucVu_HRC2").empty();
                                                        $.each(data, function (index, row) {
                                                            $("#IDChucVu_HRC2").append("<option value='" + row.iD_ChucVu + "' data-info='" + row.iD_ChucVu + "' selected>" + row.tenChucVu + "</option>");
                                                        });
                                                    } else {
                                                        $("#IDChucVu_HRC2").empty();
                                                        $("#IDChucVu_HRC2").append("<option value='0'>--Không có chức vụ--</option>");
                                                    }
                                                });
                                            });
                                        </script>
                                    </div>

                                    <!-- BP/NM -->
                                    <div class="d-flex align-items-center bg-light rounded p-2 mb-3" style="min-height: 57px; gap: 1rem;width: 31.8%;margin-right: 22px;">
                                        <span class="text-dark mb-0" style="font-size: 14px; white-space: nowrap;">
                                            BP/NM <span class="text-danger">(*)</span>:
                                        </span>
                                        <select class="form-select flex-grow-1" name="IDPhongBan" id="IDPhongBan_HRC2" disabled="disabled">
                                        </select>
                                        <script type="text/javascript">
                                            $("#IDTaiKhoanHRC2").change(function () {
                                                $.get("/BM/PhongBan", { IDTaiKhoan: $("#IDTaiKhoanHRC2").val() }, function (data) {
                                                    if (data[0] != null) {
                                                        $("#IDPhongBan_HRC2").empty();
                                                        $.each(data, function (index, row) {
                                                            $("#IDPhongBan_HRC2").append("<option value='" + row.iD_PhongBan + "' data-info='" + row.iD_PhongBan + "-" + row.iD_PhanXuong + "' selected>" + row.tenPhongBan + "</option>");
                                                        });
                                                    } else {
                                                        $("#IDPhongBan_HRC2").empty();
                                                        $("#IDPhongBan_HRC2").append("<option value='0'>--Không có chức vụ--</option>");
                                                    }
                                                });
                                            });
                                        </script>
                                    </div>
                                </div>
                                <div class="col-lg-12" style="display: flex; justify-content: space-between; padding-bottom: 1%; margin-top: -20px;">
                                    <!-- Đại diện bên nhận QLCL -->
                                    <div class="d-flex align-items-center bg-light rounded p-2 mb-3" style="min-height: 57px; width: 31.8%; gap: 1rem; margin-right: 27px;">
                                        <span class="text-dark mb-0" style="font-size: 14px; white-space: nowrap;">
                                            Đại diện Phòng QLCL <span class="text-danger">(*)</span>:
                                        </span>
                                        @Html.DropDownList("TaiKhoan_QLCL", null, "----- Chọn đại diện bên nhận -----", new
                                            {
                                                id = "IDTaiKhoan_QLCL",
                                                name = "IDTaiKhoan_QLCL",
                                                @class = "form-select flex-grow-1"
                                            })
                                    </div>
                                    <script type="text/javascript">
                                        $("#IDTaiKhoan_QLCL").change(function () {
                                            $.get("/BM/ChucVu", { IDTaiKhoan: $("#IDTaiKhoan_QLCL").val() }, function (data) {
                                                if (data[0] != null) {
                                                    $("#IDChucVu_QLCL").empty();
                                                    $.each(data, function (index, row) {
                                                        $("#IDChucVu_QLCL").append("<option value='" + row.iD_ChucVu + "' data-info='" + row.iD_ChucVu + "' selected>" + row.tenChucVu + "</option>");
                                                    });
                                                } else {
                                                    $("#IDChucVu_QLCL").empty().append("<option value='0'>--Không có chức vụ--</option>");
                                                }
                                            });

                                            $.get("/BM/PhongBan", { IDTaiKhoan: $("#IDTaiKhoan_QLCL").val() }, function (data) {
                                                if (data[0] != null) {
                                                    $("#IDPhongBan_QLCL").empty();
                                                    $.each(data, function (index, row) {
                                                        $("#IDPhongBan_QLCL").append("<option value='" + row.iD_PhongBan + "' data-info='" + row.iD_PhongBan + "-" + row.iD_PhanXuong + "' selected>" + row.tenPhongBan + "</option>");
                                                    });
                                                } else {
                                                    $("#IDPhongBan_QLCL").empty().append("<option value='0'>--Không có chức vụ--</option>");
                                                }
                                            });
                                        });
                                    </script>
                                    <!-- Chức vụ -->
                                    <div class="d-flex align-items-center bg-light rounded p-2 mb-3" style="min-height: 57px; width: 31.8%; gap: 1rem; margin-right: 22px;">
                                        <span class="text-dark mb-0" style="font-size: 14px; white-space: nowrap;">
                                            Chức vụ <span class="text-danger">(*)</span>:
                                        </span>
                                        <select class="form-select flex-grow-1" name="IDChucVu_QLCL" id="IDChucVu_QLCL" disabled="disabled">
                                        </select>
                                    </div>

                                    <!-- BP/NM -->
                                    <div class="d-flex align-items-center bg-light rounded p-2 mb-3" style="min-height: 57px; width: 31.8%; gap: 1rem; margin-right: 22px;">
                                        <span class="text-dark mb-0" style="font-size: 14px; white-space: nowrap;">
                                            BP/NM <span class="text-danger">(*)</span>:
                                        </span>
                                        <select class="form-select flex-grow-1" name="IDPhongBan_QLCL" id="IDPhongBan_QLCL" disabled="disabled">
                                        </select>
                                    </div>
                                </div>

                                <div class="col-lg-12" style="display: flex; justify-content: space-between; padding-bottom: 1%; margin-top:-25px">
                                    <!-- Đại diện bên nguyên vật liệu -->
                                    <div class="d-flex align-items-center bg-light rounded p-2 mb-3" style="min-height: 57px; width: 31.8%; gap: 1rem; margin-right: 27px;">
                                        <span class="text-dark mb-0" style="font-size: 14px; white-space: nowrap;">
                                            Nhân viên nguyên liệu <span class="text-danger">(*)</span>:
                                        </span>
                                        @Html.DropDownList("TaiKhoan_NVNL", null, "----- Chọn đại diện nhân viên nguyên liệu -----", new
                                            {
                                                id = "IDTaiKhoan_NVNL",
                                                name = "IDTaiKhoan_NVNL",
                                                @class = "form-select flex-grow-1"
                                            })
                                    </div>
                                    <script type="text/javascript">
                                        $("#IDTaiKhoan_NVNL").change(function () {
                                            $.get("/BM/ChucVu", { IDTaiKhoan: $("#IDTaiKhoan_NVNL").val() }, function (data) {
                                                if (data[0] != null) {
                                                    $("#IDChucVu_NVNL").empty();
                                                    $.each(data, function (index, row) {
                                                        $("#IDChucVu_NVNL").append("<option value='" + row.iD_ChucVu + "' data-info='" + row.iD_ChucVu + "' selected>" + row.tenChucVu + "</option>");
                                                    });
                                                } else {
                                                    $("#IDChucVu_NVNL").empty().append("<option value='0'>--Không có chức vụ--</option>");
                                                }
                                            });

                                            $.get("/BM/PhongBan", { IDTaiKhoan: $("#IDTaiKhoan_NVNL").val() }, function (data) {
                                                if (data[0] != null) {
                                                    $("#IDPhongBan_NVNL").empty();
                                                    $.each(data, function (index, row) {
                                                        $("#IDPhongBan_NVNL").append("<option value='" + row.iD_PhongBan + "' data-info='" + row.iD_PhongBan + "-" + row.iD_PhanXuong + "' selected>" + row.tenPhongBan + "</option>");
                                                    });
                                                } else {
                                                    $("#IDPhongBan_NVNL").empty().append("<option value='0'>--Không có chức vụ--</option>");
                                                }
                                            });
                                        });
                                    </script>
