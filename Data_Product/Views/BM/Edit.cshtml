                                Đại diện bên nhận HRC1 <span class="text-danger">(*)</span>:
                            </span>
                            @Html.DropDownList("IDTaiKhoan", null, "----- Chọn đại diện bên nhận -----", new
                                {
                                    id = "IDTaiKhoan",
                                    name = "IDTaiKhoan",
                                    @class = "form-select flex-grow-1"
                                })
                            <script type="text/javascript">
                                $("#IDTaiKhoan").change(function () {
                                    $.get("/BM_11/ChucVu", { IDTaiKhoan: $("#IDTaiKhoan").val() }, function (data) {
                                        if (data[0] != null) {
                                            $("#IDChucVu").empty();
                                            $.each(data, function (index, row) {
                                                $("#IDChucVu").append("<option value='" + row.iD_ChucVu + "' data-info='" + row.iD_ChucVu + "' selected>" + row.tenChucVu + "</option>");
                                            });
                                        } else {
                                            $("#IDChucVu").empty();
                                            $("#IDChucVu").append("<option value='0'>--Không có chức vụ--</option>");
                                        }
                                    });

                                    $.get("/BM/PhongBan", { IDTaiKhoan: $("#IDTaiKhoan").val() }, function (data) {
                                        if (data[0] != null) {
