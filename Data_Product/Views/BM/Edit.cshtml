                            <span id="ID_PhongBan_BG" class="text-dark flex-grow-1" data-info="@ThongTin_BG.ID_PhongBan-@PhanXuong_BG.ID_Xuong" style="font-size: 14px;">
                                @PhongBan_BG.TenPhongBan - @PhanXuong_BG.TenXuong
                            </span>
                        </div>

                    </div>
                    <div class="col-lg-12" style="display: flex; justify-content: space-between; padding-bottom: 1%; margin-top: -23px;">

                        <!-- Đại diện bên nhận HRC -->
